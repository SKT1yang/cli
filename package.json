{
  "name": "@shuiyangsuan/cli",
  "version": "0.0.1",
  "description": "A personal CLI tool for common tasks",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "by": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "rolldown -c rolldown.config.ts --watch",
    "build": "rolldown -c rolldown.config.ts",
    "prepublishOnly": "npm run build",
    "test": "bun run src/index.ts delete --help"
  },
  "keywords": [
    "cli",
    "delete",
    "file-management"
  ],
  "author": "yangguodong",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": ""
  },
  "dependencies": {
    "commander": "14.0.3",
    "fast-glob": "3.3.3"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "rolldown": "latest",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
